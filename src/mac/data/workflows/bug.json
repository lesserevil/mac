{
  "slug": "wf-bug-default",
  "name": "Bug Fix Workflow",
  "description": "Default workflow for auto-filed bugs and error reports",
  "workflow_type": "bug",
  "is_default": true,
  "definition": {
    "nodes": [
      {
        "node_key": "investigate",
        "node_type": "task",
        "role_required": "qa-engineer",
        "persona_hint": "default/qa-engineer",
        "max_attempts": 3,
        "timeout_minutes": 60,
        "instructions": "Investigate this bug by:\n1. Searching codebase for related code\n2. Reading relevant files\n3. Analyzing root cause\n4. Proposing a fix\n5. Creating an approval bead with your findings"
      },
      {
        "node_key": "pm_review",
        "node_type": "approval",
        "role_required": "product-manager",
        "persona_hint": "default/product-manager",
        "max_attempts": 1,
        "timeout_minutes": 120,
        "instructions": "Review the investigation findings and proposed fix:\n1. Assess impact and risk\n2. Verify proposed fix addresses root cause\n3. Approve or reject with feedback"
      },
      {
        "node_key": "apply_fix",
        "node_type": "task",
        "role_required": "engineering-manager",
        "persona_hint": "default/engineering-manager",
        "max_attempts": 2,
        "timeout_minutes": 30,
        "instructions": "Apply the approved fix:\n1. Apply the patch to the codebase\n2. Verify the fix works\n3. Create a commit with descriptive message"
      },
      {
        "node_key": "commit_and_push",
        "node_type": "commit",
        "role_required": "engineering-manager",
        "persona_hint": "default/engineering-manager",
        "max_attempts": 2,
        "timeout_minutes": 15,
        "instructions": "Commit and push the fix:\n1. Ensure all changes are staged\n2. Create commit with proper message\n3. Push to remote repository"
      }
    ],
    "edges": [
      {
        "from_node_key": "",
        "to_node_key": "investigate",
        "condition": "success",
        "priority": 100
      },
      {
        "from_node_key": "investigate",
        "to_node_key": "pm_review",
        "condition": "success",
        "priority": 100
      },
      {
        "from_node_key": "investigate",
        "to_node_key": "",
        "condition": "escalated",
        "priority": 90
      },
      {
        "from_node_key": "pm_review",
