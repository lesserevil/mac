        "timeout_minutes": 60,
        "instructions": "Review implementation plan:\n1. Verify completeness\n2. Assess feasibility\n3. Approve plan or request revisions"
      },
      {
        "node_key": "implement",
        "node_type": "task",
        "role_required": "engineering-manager",
        "persona_hint": "default/engineering-manager",
