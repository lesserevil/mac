# mac fleet agent config.
#
# Copy to deploy/agents/<agent>/config.env and edit. Do not put secrets here.
# Secrets still live in the mac/ACC vaults or host-local env files.

MAC_DEPLOY_AGENT=agent-name
MAC_DEPLOY_TARGET=user@host-or-tailscale-ip
MAC_DEPLOY_OS=linux

# Fleet topology. Rocky is the default shared hub; spokes keep their local
# control plane private and register their mac-agent service against the hub.
MAC_DEPLOY_HUB_URL=http://100.125.137.89:8789
# Leave unset for the default: 0.0.0.0 on the hub, 127.0.0.1 on spokes.
# MAC_DEPLOY_CONTROL_BIND_HOST=127.0.0.1

# Worker service mode. heartbeat registers and refreshes presence without
# claiming tasks; dry-run records routing candidates without leasing; loop
# enables executor-backed task claiming.
MAC_DEPLOY_WORKER_MODE=heartbeat
MAC_DEPLOY_WORKER_CAPABILITIES=ops,python,hermes
# Default loop/dry-run safety gate: workers only see tasks marked with
# metadata.canary=true, metadata.mac_canary=true, or metadata.worker_canary=true.
MAC_DEPLOY_WORKER_REQUIRE_CANARY=1
# Optional quarantine filters for loop/dry-run mode.
# MAC_DEPLOY_WORKER_ALLOWED_PROJECTS=mac-canary
# MAC_DEPLOY_WORKER_REQUIRED_METADATA={"canary":true}

# Slack channel name, without the leading "#", used to materialize
# ~/.hermes/slack_home_channels.json from configured slack_accounts.json.
MAC_HERMES_SLACK_HOME_CHANNEL_NAME=rockyandfriends
