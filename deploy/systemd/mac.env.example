# Copy to /etc/mac/mac.env (mode 0600, owner root:mac) and edit before
# enabling mac.service.
#
# Generate the secret key once:
#   openssl rand -base64 48

MAC_SECRET_KEY=REPLACE-ME-WITH-A-32-PLUS-CHAR-RANDOM-STRING

# Database location. Defaults to ./mac.db relative to WorkingDirectory.
MAC_DB=/var/lib/mac/mac.db

# Hermes state/startup contract. These checks are metadata-only; contents of
# souls, memories, auth files, and Slack accounts are not returned by mac.
HERMES_HOME=/home/mac/.hermes
ACC_DIR=/home/mac/.acc
# Slack home-channel discovery writes slack_home_channels.json from
# slack_accounts.json. Set without the leading "#".
MAC_HERMES_SLACK_HOME_CHANNEL_NAME=
MAC_HERMES_SYNC_SLACK_HOME_CHANNELS=1
# MAC_HERMES_AGENT_DIR=/opt/hermes-agent
# MAC_HERMES_APPLY_SLACK_ACCOUNT_SHIM=1
# MAC_HERMES_APPLY_GATEWAY_RUNTIME_SHIM=1
# MAC_HERMES_GATEWAY_MODEL=azure/openai/gpt-5.5
# MAC_HERMES_GATEWAY_PROVIDER=custom
# MAC_HERMES_GATEWAY_BASE_URL=http://tokenhub.example:8090/v1
# MAC_SELF_UPDATE_REPO=/opt/mac
# MAC_REQUIRE_HERMES_STARTUP_READY=1
# MAC_HERMES_STARTUP_CHECK=1
MAC_URL=http://hub.example.internal:8789
MAC_FLEET_TENANT_ID=tenant_example
MAC_AGENT_ID=agent_example
MAC_HERMES_PERSONA_ID=persona_example
MAC_HERMES_INSTANCE_ID=hermes_example
MAC_WORKER_HERMES_INSTANCE_ID=hermes_example
MAC_HERMES_RUNTIME_CONTEXT_FILE=/home/mac/.hermes/mac-runtime-context.json
MAC_HERMES_RUNTIME_CONTEXT_MARKDOWN=/home/mac/.hermes/mac-runtime-context.md
MAC_HERMES_RUNTIME_CONTEXT_REQUIRED=1
MAC_HERMES_WORKSPACE=/home/mac/.mac/src/mac
MAC_PROJECT_CONTRACT_FILE=/home/mac/.mac/src/mac/.mac/project.yaml
MAC_WORKER_EXECUTOR=/home/mac/.mac/bin/mac-hermes-task-executor

# Hub-managed TokenHub service. The hub owns upstream provider API keys and
# model routing; MAC and Hermes keep only a TokenHub client key.
MAC_REQUIRE_TOKENHUB=1
TOKENHUB_URL=http://hub.example.internal:8090
TOKENHUB_API_KEY=tokenhub_REPLACE_ME
OPENAI_API_KEY=tokenhub_REPLACE_ME
MAC_HERMES_GATEWAY_API_KEY=tokenhub_REPLACE_ME
OPENAI_BASE_URL=http://hub.example.internal:8090/v1
CUSTOM_BASE_URL=http://hub.example.internal:8090/v1
MAC_HERMES_GATEWAY_PROVIDER=custom
MAC_HERMES_GATEWAY_MODEL=*
HERMES_INFERENCE_PROVIDER=custom
HERMES_INFERENCE_MODEL=*

# Supervisor/topology metadata. Fleet deploy sets this dynamically to systemd,
# launchd, or supervisord.
# MAC_SUPERVISOR_KIND=systemd

# Hub-managed shared memory service. The hub owns Qdrant; spokes point at the
# hub URL. Startup readiness validates /collections and reports redacted
# topology in /startup/hermes.
MAC_SHARED_SERVICES_MANAGER_AGENT=hub
MAC_MEMORY_TOPOLOGY_FILE=/home/mac/.hermes/mac-memory-topology.json
MAC_REQUIRE_QDRANT_MEMORY=1
MAC_QDRANT_MEMORY_ROLE=shared_level2
QDRANT_URL=http://hub.example.internal:6333
QDRANT_ADDRESS=http://hub.example.internal:6333
QDRANT_FLEET_URL=http://hub.example.internal:6333
# QDRANT_API_KEY=
# MAC_QDRANT_MEMORY_ALLOW_DEGRADED=0

# Hub-managed Firecrawl-compatible web search service. The hub exposes the
# endpoint and all agents use it for Hermes web search/extraction tools.
MAC_REQUIRE_FIRECRAWL=1
MAC_WEB_SEARCH_PROVIDER=firecrawl
MAC_WEB_SEARCH_URL=http://hub.example.internal:3002
FIRECRAWL_API_URL=http://hub.example.internal:3002
FIRECRAWL_GATEWAY_URL=http://hub.example.internal:3002
FIRECRAWL_API_KEY=none
HERMES_WEB_SEARCH_BACKEND=firecrawl
HERMES_WEB_EXTRACT_BACKEND=firecrawl
# MAC_FIRECRAWL_ALLOW_DEGRADED=0

# Bearer auth — pick ONE.
# Single admin token:
# MAC_API_TOKEN=<random-token-here>
#
# Or scoped tokens (JSON):
# MAC_API_TOKENS={"reader":["read"],"worker":["agent","dispatch"],"ops":["admin"]}
