# Copy to /etc/mac/mac.env (mode 0600, owner root:mac) and edit before
# enabling mac.service.
#
# Generate the secret key once:
#   openssl rand -base64 48

MAC_SECRET_KEY=REPLACE-ME-WITH-A-32-PLUS-CHAR-RANDOM-STRING

# Database location. Defaults to ./mac.db relative to WorkingDirectory.
MAC_DB=/var/lib/mac/mac.db

# Hermes state/startup contract. These checks are metadata-only; contents of
# souls, memories, auth files, and Slack accounts are not returned by mac.
HERMES_HOME=/home/mac/.hermes
ACC_DIR=/home/mac/.acc
# MAC_HERMES_AGENT_DIR=/opt/hermes-agent
# MAC_HERMES_APPLY_SLACK_ACCOUNT_SHIM=1
# MAC_REQUIRE_HERMES_STARTUP_READY=1
# MAC_HERMES_STARTUP_CHECK=1

# Bearer auth — pick ONE.
# Single admin token:
# MAC_API_TOKEN=<random-token-here>
#
# Or scoped tokens (JSON):
# MAC_API_TOKENS={"reader":["read"],"worker":["agent","dispatch"],"ops":["admin"]}
