+def _load_mac_runtime_context() -> str:
+    """Load MAC task/project runtime context from HERMES_HOME.
+
+    Fleet deployments write this file so Hermes sessions see MAC's
+    authoritative task/project/agent contract in the same prompt tier as
+    AGENTS.md and other operator instructions.
+    """
+    candidates = []
+    configured = os.getenv("MAC_HERMES_RUNTIME_CONTEXT_MARKDOWN", "").strip()
+    if configured:
+        path = Path(configured).expanduser()
+        if not path.is_absolute():
+            path = get_hermes_home() / path
+        candidates.append(path)
+    default_path = get_hermes_home() / "mac-runtime-context.md"
+    if default_path not in candidates:
+        candidates.append(default_path)
+    for path in candidates:
+        if not path.exists() or not path.is_file():
+            continue
+        try:
+            content = path.read_text(encoding="utf-8").strip()
+            if not content:
+                continue
+            content = _scan_context_content(content, path.name)
+            result = "## MAC Task and Project Runtime\n\n" + content
+            return _truncate_content(result, path.name)
+        except Exception as e:
+            logger.debug("Could not read MAC runtime context from %s: %s", path, e)
+    return ""
+
+
 def _load_hermes_md(cwd_path: Path) -> str:
     """.hermes.md / HERMES.md — walk to git root."""
